{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make check:*)",
      "Bash(make install:*)",
      "Bash(docker compose:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter build:*)",
      "Bash(flutter run:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(xcrun simctl:*)",
      "Bash(~/Library/Android/sdk/platform-tools/adb:*)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(composer require:*)",
      "Bash(composer remove:*)",
      "Bash(composer update:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rm -f:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
